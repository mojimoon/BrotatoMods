[gd_resource type="Resource" load_steps=100 format=2]

; replace load_steps with the following number of resources plus one

[ext_resource path="res://mods-unpacked/Darkly77-ContentLoader/content_data.gd" type="Script" id=1]

; weapons
; e.g. [ext_resource path="res://mods-unpacked/Neel-Lv1Weapon/content/weapons/melee/circular_saw/1/circular_saw_1_data.tres" type="Resource" id=2]

; characters
; e.g. [ext_resource path="res://items/characters/well_rounded/well_rounded_data.tres" type="Resource" id=3]

[resource]
script = ExtResource( 1 )
characters = [  ]
items = [  ]
weapons = [  ]
; each item in weapons corresponds to a weapons_characters array, which includes what characters can start with that weapon
weapons_characters = [  ]
sets = [  ]
challenges = [  ]
upgrades = [  ]
consumables = [  ]
elites = [  ]
difficulties = [  ]
debug_items = [  ]
debug_weapons = [  ]
